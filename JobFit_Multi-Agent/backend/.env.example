# JobFit Multi-Agent 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# Flask配置
SECRET_KEY=your-secret-key-here
DEBUG=True

# LLM API配置（使用Ollama本地模型）
LLM_API_URL=http://localhost:11434/api/chat
LLM_API_KEY=
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.7

# OCR配置
OCR_ENABLED=True

# Tesseract OCR 引擎路径（可选）
# Windows示例: TESSERACT_PATH=D:\\Program Files\\Tesseract-OCR\\tesseract.exe
# Linux/Docker示例: TESSERACT_PATH=/usr/bin/tesseract
# Mac示例: TESSERACT_PATH=/usr/local/bin/tesseract
# 留空则使用系统PATH查找
TESSERACT_PATH=
