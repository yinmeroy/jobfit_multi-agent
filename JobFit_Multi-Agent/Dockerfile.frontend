# JobFit Multi-Agent Frontend Dockerfile
FROM node:18-alpine AS build

# 设置工作目录
WORKDIR /app

# 复制依赖文件
COPY frontend/package*.json ./

# 安装依赖
RUN npm install

# 复制项目文件
COPY frontend/ .

# 构建生产版本
RUN npm run build

# 使用 Nginx 提供静态文件
FROM nginx:alpine

# 复制构建产物到 Nginx
COPY --from=build /app/dist /usr/share/nginx/html

# 复制自定义 Nginx 配置（可选）
# COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf

# 暴露端口
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
